{
  "manifest_version": 3,
  "name": "de-Algorithm",
  "version": "0.2.3",
  "description": "Blocks Reddit/YouTube feeds and bounces you back to Firefox home. Hides YouTube suggested sidebar on watch pages.",
  "permissions": [
    "webNavigation",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*.reddit.com/*",
    "*://reddit.com/*",
    "*://*.youtube.com/*",
    "*://youtube.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": [
        "youtube-watch.js"
      ],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "@De-Algorithm",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}